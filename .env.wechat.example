# 微信环境变量配置示例

# 复制此文件为 .env 并填入真实值

# 微信公众号 AppID
WECHAT_APPID=wxd213e22f3178383b

# 微信公众号 AppSecret
WECHAT_APPSECRET=5664bceb1f6db3ed3609813e304d1bcd

# 微信公众号 Token（自己设置，需与后台一致）
# 注意：只能包含字母和数字，长度3-32字符
WECHAT_TOKEN=clawnet

# 消息加密密钥（可选，启用加密模式时需要）
WECHAT_ENCODING_AES_KEY=xHzdvi3xjZLXUetUadtlyFM1h9epCkGJswIUbdd8Z0k

# ===== 重要说明 =====
# Token 规则：
# - 只能包含：英文字母、数字
# - 长度：3-32字符
# - 不能有：横线(-)、下划线(_)、空格等特殊字符
#
# 正确示例：clawnet, mytoken123, wechat2026
# 错误示例：clawnet-mp, my_token, token 123