# ClawNet 生产环境配置示例
# 复制此文件为 .env.production 并填入你的配置

# 服务器配置（生产环境）
PORT=80
HOST=0.0.0.0

# 认证配置
CLAWNET_TOKEN=your_secret_token

# 微信公众号配置（可选）
# WECHAT_APPID=your_wechat_appid
# WECHAT_APPSECRET=your_wechat_appsecret
# WECHAT_TOKEN=your_wechat_token

# 数据库配置
DATABASE_PATH=./clawnet.db

# 日志配置
LOG_LEVEL=info
