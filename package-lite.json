    "telegram",
    "websocket",
    "graph",
    "topology",
    "lite",
    "no-native"
  ],
  "author": "husile",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bsheepcoder/ClawNet.git"
  },
  "bugs": {
    "url": "https://github.com/Bsheepcoder/ClawNet/issues"
  },
  "homepage": "https://github.com/Bsheepcoder/ClawNet#readme",
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "cors": "^2.8.0",
    "express": "^4.18.0",
    "ws": "^8.0.0"
